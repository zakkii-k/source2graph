{
  "name": "codenexus",
  "version": "0.1.0",
  "description": "Source code graph analyzer for Java, TypeScript, and JavaScript",
  "type": "module",
  "bin": {
    "codenexus": "./dist/cli/index.js"
  },
  "scripts": {
